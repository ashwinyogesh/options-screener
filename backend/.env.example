# Azure OpenAI (for Supply Chain extraction)
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# SEC EDGAR requires a User-Agent with contact info
SEC_USER_AGENT=Options Screener app@example.com

# Cosmos DB — shared backing store for DD Coach + screener precomputed results.
# DefaultAzureCredential uses `az login` locally; App Service uses Managed Identity.
# The env var name is historical (the account was originally provisioned for the
# narrative platform). Account + DB names live in infra/modules/cosmos.bicep.
NARRATIVE_COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
NARRATIVE_COSMOS_DB=narrative

# DD Coach — Cosmos container name. Default matches infra/modules/cosmos.bicep.
DD_COACH_COSMOS_CONTAINER=dd_entries

# DD Coach V3 — LLM filings intelligence cache + on-disk raw filing cache.
# Reuses AZURE_OPENAI_* + NARRATIVE_COSMOS_* above for the LLM and Cosmos.
DD_FILINGS_INTEL_CONTAINER=dd_filings_intel
DD_FILINGS_CACHE_DIR=data/dd_filings_cache
